# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cv_analyzer
POSTGRES_DB=cv_analyzer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Auth ──────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MercadoPago (Sandbox) ────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=TEST-your-access-token
MERCADOPAGO_PUBLIC_KEY=TEST-your-public-key

# ── AI Providers ─────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
CEREBRAS_API_KEY=your-cerebras-api-key
CEREBRAS_MODEL=llama3.1-8b
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-120b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── AI Service ──────────────────────────────────────────
AI_MAX_RETRIES=2
AI_TIMEOUT_SECONDS=120

# ── Email (Gmail SMTP) ───────────────────────────────────
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# ── Billing ───────────────────────────────────────────────
FREE_ANALYSIS_LIMIT=3
ANALYSIS_PRICE_USD=2.99

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
